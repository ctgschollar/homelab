#!/bin/bash
# chain_skill — prepend a skill entry to the front of the queue
# Usage: chain_skill <skill> [args...]
# Env: NAME (instance name)
set -euo pipefail

BASE_DIR="${CLAUDE_RUNNER_BASE_DIR:-/opt/claude-runner}"

if [[ $# -lt 1 ]]; then
    echo "chain_skill: requires <skill> [args...]" >&2
    exit 1
fi

SKILL="$1"
shift
SKILL_ARGS="$*"

QUEUE_FILE="${BASE_DIR}/tasks/${NAME}/queue"

if [[ -n "$SKILL_ARGS" ]]; then
    NEW_ENTRY="${SKILL} ${SKILL_ARGS}"
else
    NEW_ENTRY="${SKILL}"
fi

# Prepend to queue atomically using flock
(
    flock -x 200
    TMP=$(mktemp)
    echo "$NEW_ENTRY" > "$TMP"
    if [[ -f "$QUEUE_FILE" ]]; then
        cat "$QUEUE_FILE" >> "$TMP"
    fi
    mv "$TMP" "$QUEUE_FILE"
) 200>"${QUEUE_FILE}.lock"

echo "Chained skill '${SKILL}' to front of queue for ${NAME}"
