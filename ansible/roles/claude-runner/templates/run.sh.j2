#!/bin/bash
# Managed by Ansible — do not edit directly.
# Source: ansible/roles/claude-runner/templates/run.sh.j2

REPO_PATH="${1:?Usage: run.sh <repo-path> <name>}"
NAME="${2:?Usage: run.sh <repo-path> <name>}"
TASK_FILE="{{ claude_runner_base_dir }}/tasks/${NAME}.md"
LOG_FILE="{{ claude_runner_base_dir }}/logs/${NAME}.log"

cd "$REPO_PATH"

while true; do
    if [[ ! -f "$TASK_FILE" ]]; then
        echo "$(date -Iseconds) No task file found. Use: claude-runner add-instruction ${NAME} 'your instructions'" | tee -a "$LOG_FILE"
        sleep 30
        continue
    fi

    claude --print --dangerously-skip-permissions < "$TASK_FILE" 2>&1 | tee -a "$LOG_FILE"
    sleep 5
done
