$ORIGIN schollar.dev.
$TTL 300
@   IN SOA ns.schollar.dev. hostmaster.schollar.dev. (
        2026050401   ; serial
        3600       ; refresh
        600        ; retry
        604800     ; expire
        300 )      ; minimum

    IN NS  ns.schollar.dev.
ns  IN A   192.168.3.70

; --- Hosts
mikrotik     IN A  192.168.3.1
rpi01        IN A  192.168.3.2
claude-nunya IN A  192.168.3.50
dks01        IN A  192.168.3.70
dks02        IN A  192.168.3.71
dks03        IN A  192.168.3.72
dks04        IN A  192.168.3.73
dks05        IN A  192.168.3.74
claude-runner IN A  192.168.3.79
edge         IN A  192.168.3.91
prx01        IN A  192.168.3.101
prx02        IN A  192.168.3.102
prx03        IN A  192.168.3.103
prx04        IN A  192.168.3.104
prx05        IN A  192.168.3.105
desktop      IN A  192.168.3.241

; --- Wildcard -> Traefik
*   IN A  192.168.3.70
    IN A  192.168.3.71
    IN A  192.168.3.72
@   IN A  192.168.3.70
