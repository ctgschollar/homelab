# Registry and image version
REGISTRY=gitea.schollar.dev
VERSION=latest

# Domain (must match a Traefik-routed hostname)
DOMAIN=red-dev.schollar.dev

# Backend
SECRET_KEY=changeme-use-a-long-random-string
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme
BACKEND_CORS_ORIGINS=["https://red-dev.schollar.dev"]

# Database — shared postgres on the homelab
POSTGRES_SERVER=pg.schollar.dev
POSTGRES_USER=red_dev
POSTGRES_PASSWORD=changeme
POSTGRES_DB=red_ui_dev

# Auth0 (real dev tenant credentials)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_AUDIENCE=your-audience

# Sentry — leave blank to disable
SENTRY_DSN=

# Ceph — set to true to use the mock wrapper (no real Ceph needed)
CEPH_MOCK=true

# Optional: disable background sync tasks (safe to leave true when mocked)
BACKGROUND_BUCKET_UPDATE=false
BACKGROUND_CEPH_UPDATE=false
